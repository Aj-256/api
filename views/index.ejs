<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>AJ YT Search - YouTube Search API</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh;
            color: #fff;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        /* Navbar */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            padding: 20px 0;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 40px;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .logo-icon {
            font-size: 2rem;
        }
        
        .logo-text {
            font-size: 1.5rem;
            font-weight: bold;
        }
        
        .logo-text span {
            color: #ff6b6b;
        }
        
        .nav-links {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }
        
        .nav-links a {
            color: #fff;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 25px;
            transition: all 0.3s;
        }
        
        .nav-links a:hover, .nav-links a.active {
            background: rgba(255,255,255,0.2);
        }
        
        /* Hero Section */
        .hero {
            text-align: center;
            padding: 50px 20px;
        }
        
        .hero h1 {
            font-size: 3rem;
            margin-bottom: 15px;
        }
        
        .hero h1 span {
            background: linear-gradient(135deg, #ff6b6b, #4ecdc4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .hero p {
            font-size: 1.2rem;
            opacity: 0.8;
            margin-bottom: 30px;
        }
        
        /* Search Box */
        .search-box {
            background: rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 30px;
            margin: 30px 0;
            backdrop-filter: blur(10px);
        }
        
        .search-form {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }
        
        .search-input {
            flex: 1;
            padding: 15px 20px;
            font-size: 1rem;
            border: none;
            border-radius: 50px;
            outline: none;
            background: rgba(255,255,255,0.9);
        }
        
        .search-btn {
            padding: 15px 30px;
            background: linear-gradient(135deg, #ff6b6b, #4ecdc4);
            border: none;
            border-radius: 50px;
            color: white;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s;
        }
        
        .search-btn:hover {
            transform: scale(1.05);
        }
        
        /* API Cards */
        .api-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin: 40px 0;
        }
        
        .api-card {
            background: rgba(255,255,255,0.1);
            border-radius: 15px;
            padding: 20px;
            backdrop-filter: blur(10px);
            transition: transform 0.3s;
        }
        
        .api-card:hover {
            transform: translateY(-5px);
        }
        
        .method {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 0.8rem;
            margin-bottom: 10px;
        }
        
        .method.get { background: #10b981; }
        .method.post { background: #3b82f6; }
        .method.put { background: #f59e0b; }
        .method.delete { background: #ef4444; }
        
        .endpoint {
            font-family: monospace;
            font-size: 0.85rem;
            margin: 10px 0;
            word-break: break-all;
            background: rgba(0,0,0,0.3);
            padding: 10px;
            border-radius: 8px;
        }
        
        .copy-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            color: white;
            cursor: pointer;
            margin-top: 10px;
            font-size: 0.8rem;
        }
        
        .copy-btn:hover {
            background: rgba(255,255,255,0.3);
        }
        
        /* Results */
        .results {
            margin-top: 40px;
        }
        
        .result-card {
            display: flex;
            gap: 15px;
            background: rgba(255,255,255,0.1);
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 15px;
            flex-wrap: wrap;
        }
        
        .result-card img {
            width: 120px;
            border-radius: 10px;
        }
        
        .result-info {
            flex: 1;
        }
        
        .result-title {
            font-size: 1.1rem;
            margin-bottom: 8px;
        }
        
        .result-title a {
            color: #fff;
            text-decoration: none;
        }
        
        .result-title a:hover {
            color: #4ecdc4;
        }
        
        .result-meta {
            font-size: 0.85rem;
            opacity: 0.7;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }
        
        /* Team Section */
        .team {
            margin: 60px 0;
            text-align: center;
        }
        
        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            margin-top: 30px;
        }
        
        .team-card {
            background: rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 25px;
            backdrop-filter: blur(10px);
            transition: transform 0.3s;
        }
        
        .team-card:hover {
            transform: translateY(-5px);
        }
        
        .team-avatar {
            width: 100px;
            height: 100px;
            margin: 0 auto 15px;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(135deg, #ff6b6b, #4ecdc4);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .team-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .team-avatar span {
            font-size: 3rem;
        }
        
        .team-name {
            font-size: 1.3rem;
            margin-bottom: 5px;
        }
        
        .team-role {
            font-size: 0.85rem;
            opacity: 0.7;
            margin-bottom: 15px;
        }
        
        .team-social {
            display: flex;
            gap: 15px;
            justify-content: center;
        }
        
        .team-social a {
            color: #fff;
            text-decoration: none;
            padding: 5px 10px;
            background: rgba(255,255,255,0.2);
            border-radius: 20px;
            font-size: 0.8rem;
        }
        
        /* Error */
        .error {
            background: rgba(239,68,68,0.2);
            border-left: 4px solid #ef4444;
            padding: 15px;
            border-radius: 10px;
            margin: 20px 0;
        }
        
        /* Footer */
        .footer {
            text-align: center;
            padding: 30px 0;
            margin-top: 50px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2rem;
            }
            
            .navbar {
                flex-direction: column;
                text-align: center;
            }
            
            .result-card {
                flex-direction: column;
            }
            
            .result-card img {
                width: 100%;
                max-width: 200px;
            }
        }
        
        .status-badge {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #10b981;
            margin-right: 8px;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .domain-text {
            color: #4ecdc4;
            font-weight: bold;
        }
        
        .endpoint-url {
            color: #ff6b6b;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Navbar -->
        <nav class="navbar">
            <div class="logo">
                <span class="logo-icon">🎬</span>
                <span class="logo-text">AJ <span>YT Search</span></span>
            </div>
            <div class="nav-links">
                <a href="/" class="<%= activePage === 'home' ? 'active' : '' %>">Home</a>
                <a href="/docs" class="<%= activePage === 'docs' ? 'active' : '' %>">API Docs</a>
                <a href="https://github.com/Aj-256" target="_blank">GitHub</a>
            </div>
        </nav>
        
        <% if (activePage === 'home') { %>
        <!-- Hero Section -->
        <div class="hero">
            <h1>YouTube Search <span>API</span></h1>
            <p>Fast, reliable, and easy to use YouTube search for developers</p>
        </div>
        
        <!-- Search Box -->
        <div class="search-box">
            <form action="/search" method="POST" class="search-form">
                <input type="text" name="query" class="search-input" placeholder="Search YouTube videos..." value="<%= query %>" required>
                <button type="submit" class="search-btn">🔍 Search</button>
            </form>
        </div>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error">⚠️ <%= error %></div>
        <% } %>
        
        <!-- Results -->
        <% if (results && results.length > 0) { %>
            <div class="results">
                <h2>Results for "<%= query %>"</h2>
                <% results.forEach(video => { %>
                    <div class="result-card">
                        <img src="<%= video.thumbnail %>" alt="<%= video.title %>">
                        <div class="result-info">
                            <div class="result-title">
                                <a href="<%= video.url %>" target="_blank"><%= video.title %></a>
                            </div>
                            <div class="result-meta">
                                <span>👤 <%= video.author.name %></span>
                                <span>👁️ <%= (video.views / 1000).toFixed(1) %>K views</span>
                                <span>⏱️ <%= video.duration %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
        <% } %>
        
        <% if (activePage === 'docs') { %>
        <!-- API Documentation -->
        <div class="hero">
            <h1>API <span>Documentation</span></h1>
            <p>Use these endpoints with your domain: <span class="domain-text" id="currentDomain">loading...</span></p>
        </div>
        
        <div class="api-cards">
            <!-- GET Method -->
            <div class="api-card">
                <span class="method get">GET</span>
                <div class="endpoint">
                    <span id="getEndpoint">/api/search?q=javascript</span>
                </div>
                <p>Search YouTube videos with query parameter</p>
                <button class="copy-btn" onclick="copyText(document.getElementById('getEndpoint').innerText)">📋 Copy URL</button>
                <button class="copy-btn" onclick="copyText('fetch(\'' + getFullUrl() + '/api/search?q=javascript\')')">📋 Copy Fetch</button>
            </div>
            
            <!-- POST Method -->
            <div class="api-card">
                <span class="method post">POST</span>
                <div class="endpoint">
                    <span id="postEndpoint">/api/search</span>
                </div>
                <p>Send JSON: {"query": "search term", "limit": 10}</p>
                <button class="copy-btn" onclick="copyText(getFullUrl() + '/api/search')">📋 Copy URL</button>
                <button class="copy-btn" onclick="copyPostExample()">📋 Copy Fetch</button>
            </div>
            
            <!-- PUT Method -->
            <div class="api-card">
                <span class="method put">PUT</span>
                <div class="endpoint">
                    <span id="putEndpoint">/api/search</span>
                </div>
                <p>Update with filters: {"query": "tech", "minViews": 100000}</p>
                <button class="copy-btn" onclick="copyText(getFullUrl() + '/api/search')">📋 Copy URL</button>
                <button class="copy-btn" onclick="copyPutExample()">📋 Copy Fetch</button>
            </div>
            
            <!-- DELETE Method -->
            <div class="api-card">
                <span class="method delete">DELETE</span>
                <div class="endpoint">
                    <span id="deleteEndpoint">/api/search</span>
                </div>
                <p>Clear search history (demo)</p>
                <button class="copy-btn" onclick="copyText(getFullUrl() + '/api/search')">📋 Copy URL</button>
                <button class="copy-btn" onclick="copyDeleteExample()">📋 Copy Fetch</button>
            </div>
        </div>
        
        <div class="search-box">
            <h3>📡 Try API Live</h3>
            <div class="search-form">
                <input type="text" id="apiQuery" class="search-input" placeholder="Enter search query...">
                <select id="apiMethod" class="search-input" style="width: auto;">
                    <option value="GET">GET</option>
                    <option value="POST">POST</option>
                    <option value="PUT">PUT</option>
                    <option value="DELETE">DELETE</option>
                </select>
                <button onclick="testAPI()" class="search-btn">🚀 Test API</button>
            </div>
            <pre id="apiResponse" style="margin-top:20px; background:rgba(0,0,0,0.3); padding:15px; border-radius:10px; overflow-x:auto; display:none; font-size:0.8rem;"></pre>
        </div>
        
        <!-- Code Examples -->
        <div class="search-box">
            <h3>💻 Code Examples</h3>
            
            <h4>JavaScript (Fetch)</h4>
            <pre style="background:rgba(0,0,0,0.3); padding:15px; border-radius:10px; overflow-x:auto; margin:10px 0;">
<code>// GET Request
fetch('<span id="codeGetUrl">https://your-domain.com</span>/api/search?q=javascript')
  .then(res => res.json())
  .then(data => console.log(data));

// POST Request
fetch('<span id="codePostUrl">https://your-domain.com</span>/api/search', {
  method: 'POST',
  headers: {'Content-Type': 'application/json'},
  body: JSON.stringify({query: 'music', limit: 5})
})
  .then(res => res.json())
  .then(data => console.log(data));</code></pre>

            <h4>cURL</h4>
            <pre style="background:rgba(0,0,0,0.3); padding:15px; border-radius:10px; overflow-x:auto; margin:10px 0;">
<code># GET Request
curl "<span id="curlGetUrl">https://your-domain.com</span>/api/search?q=javascript"

# POST Request
curl -X POST <span id="curlPostUrl">https://your-domain.com</span>/api/search \
  -H "Content-Type: application/json" \
  -d '{"query":"music","limit":5}'</code></pre>

            <h4>Python</h4>
            <pre style="background:rgba(0,0,0,0.3); padding:15px; border-radius:10px; overflow-x:auto; margin:10px 0;">
<code>import requests

# GET Request
response = requests.get('<span id="pythonGetUrl">https://your-domain.com</span>/api/search?q=javascript')
data = response.json()

# POST Request
response = requests.post('<span id="pythonPostUrl">https://your-domain.com</span>/api/search', 
                        json={'query': 'music', 'limit': 5})</code></pre>
        </div>
        <% } %>
        
        <!-- Team Section -->
        <div class="team">
            <h2>👥 Development Team</h2>
            <p>Built by passionate developers</p>
            <div class="team-grid">
                <div class="team-card">
                    <div class="team-avatar">
                        <img src="https://github.com/Aj-256.png" alt="AJ">
                    </div>
                    <div class="team-name">AJ</div>
                    <div class="team-role">Lead Developer & API Architect</div>
                    <div class="team-social">
                        <a href="https://github.com/Aj-256" target="_blank">🐙 GitHub</a>
                        <a href="https://vero-upload.zone.id/files/1767101841497_drj4iscx09i.jpg" target="_blank">📷 Portfolio</a>
                    </div>
                </div>
                
                <div class="team-card">
                    <div class="team-avatar">
                        <span>👨‍💻</span>
                    </div>
                    <div class="team-name">Alex Chen</div>
                    <div class="team-role">Frontend Engineer</div>
                    <div class="team-social">
                        <a href="#">🐙 GitHub</a>
                        <a href="#">🔗 LinkedIn</a>
                    </div>
                </div>
                
                <div class="team-card">
                    <div class="team-avatar">
                        <span>👩‍🎨</span>
                    </div>
                    <div class="team-name">Sarah Johnson</div>
                    <div class="team-role">UI/UX Designer</div>
                    <div class="team-social">
                        <a href="#">🎨 Portfolio</a>
                        <a href="#">⚽ Dribbble</a>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Footer -->
        <div class="footer">
            <p>© 2024 AJ YT Search | <span class="status-badge"></span> API Status: Online</p>
            <p style="margin-top:10px; font-size:0.8rem;">✅ All HTTP Methods: GET | POST | PUT | DELETE</p>
            <p style="margin-top:5px; font-size:0.7rem; opacity:0.6;">📍 Base URL: <span id="footerDomain">https://your-domain.com</span></p>
        </div>
    </div>
    
    <script>
        // Get current domain
        function getFullUrl() {
            return window.location.origin;
        }
        
        // Update all domain displays
        function updateDomain() {
            const domain = getFullUrl();
            const domains = document.querySelectorAll('#currentDomain, #footerDomain, #codeGetUrl, #codePostUrl, #curlGetUrl, #curlPostUrl, #pythonGetUrl, #pythonPostUrl, #getEndpoint, #postEndpoint, #putEndpoint, #deleteEndpoint');
            domains.forEach(el => {
                if (el && el.id !== 'getEndpoint' && el.id !== 'postEndpoint' && el.id !== 'putEndpoint' && el.id !== 'deleteEndpoint') {
                    el.textContent = domain;
                }
            });
            // Update endpoint displays
            const getEndpointEl = document.getElementById('getEndpoint');
            if (getEndpointEl) getEndpointEl.textContent = domain + '/api/search?q=javascript';
        }
        
        // Copy functions
        function copyText(text) {
            navigator.clipboard.writeText(text);
            alert('✅ Copied to clipboard!');
        }
        
        function copyPostExample() {
            const domain = getFullUrl();
            const code = `fetch('${domain}/api/search', {
  method: 'POST',
  headers: {'Content-Type': 'application/json'},
  body: JSON.stringify({query: 'music', limit: 10})
})`;
            copyText(code);
        }
        
        function copyPutExample() {
            const domain = getFullUrl();
            const code = `fetch('${domain}/api/search', {
  method: 'PUT',
  headers: {'Content-Type': 'application/json'},
  body: JSON.stringify({query: 'coding', minViews: 100000})
})`;
            copyText(code);
        }
        
        function copyDeleteExample() {
            const domain = getFullUrl();
            const code = `fetch('${domain}/api/search', {
  method: 'DELETE'
})`;
            copyText(code);
        }
        
        // Test API function
        async function testAPI() {
            const query = document.getElementById('apiQuery').value;
            const method = document.getElementById('apiMethod').value;
            const responseDiv = document.getElementById('apiResponse');
            const domain = getFullUrl();
            
            if (!query && method !== 'DELETE') {
                alert('⚠️ Please enter a search query');
                return;
            }
            
            responseDiv.style.display = 'block';
            responseDiv.textContent = '⏳ Loading...';
            
            try {
                let url = `${domain}/api/search`;
                let options = { method: method };
                
                if (method === 'GET') {
                    url = `${domain}/api/search?q=${encodeURIComponent(query)}`;
                } else if (method === 'POST' || method === 'PUT') {
                    options.headers = { 'Content-Type': 'application/json' };
                    options.body = JSON.stringify({ query: query, limit: 10 });
                }
                
                const res = await fetch(url, options);
                const data = await res.json();
                responseDiv.textContent = JSON.stringify(data, null, 2);
            } catch (error) {
                responseDiv.textContent = '❌ Error: ' + error.message;
            }
        }
        
        // Run on load
        updateDomain();
        
        // Auto-detect domain change
        setInterval(updateDomain, 1000);
    </script>
</body>
</html>